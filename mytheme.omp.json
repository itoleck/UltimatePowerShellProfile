{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "transient_prompt": {
    "template": "{{ .Shell }}> ",
    "foreground": "#ffffff",
    "background": "transparent"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "prefix": " \ufd31",
            "template": " {{.Context}}{{if .Namespace}} :: {{.Namespace}}{{end}}"
          },
          "foreground": "#000000",
          "background": "#ffea00",
          "type": "kubectl",
          "style": "powerline"
        },
        {
          "properties": {
            "prefix": " \ufd03",
            "template": " Connected to Cloud -> {{ .ID }} : {{.Name}}"
          },
          "leading_diamond": "\ue0c7\u2593",
          "trailing_diamond": "\ue0b0",
          "foreground": "#000000",
          "background": "#008AD7",
          "type": "az",
          "style": "diamond"
        },
        {
          "properties": {
            "display_default": false,
            "prefix": " \ue7ad "
          },
          "leading_diamond": "\ue0c7\u2593",
          "trailing_diamond": "\ue0b0",
          "foreground": "#ffffff",
          "type": "aws",
          "style": "diamond",
          "background_templates": [
            "{{if contains \"default\" .Profile}}#FFA400{{end}}",
            "{{if contains \"chad\" .Profile}}#f1184c{{end}}"
          ]
        },
        {
          "properties": {
            "charged_icon": "\ue22f ",
            "charging_icon": "\ue234 ",
            "discharging_icon": "\ue231 ",
            "postfix": "\uf295 "
          },
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#f36943",
          "type": "battery",
          "style": "powerline",
          "background_templates": [
            "{{if eq \"Charging\" .State.String}}#40c4ff{{end}}",
            "{{if eq \"Discharging\" .State.String}}#ff5722{{end}}",
            "{{if eq \"Full\" .State.String}}#4caf50{{end}}"
          ]
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "display_host": true,
            "prefix": ""
          },
          "leading_diamond": "\ue0c7\u2593",
          "foreground": "#ffffff",
          "background": "#9A348E",
          "type": "session",
          "style": "diamond"
        },
        {
          "properties": {
            "folder_separator_icon": "\ue0b1",
            "home_icon": "~",
            "prefix": " \uf74a ",
            "style": "folder"
          },
          "foreground": "#011627",
          "powerline_symbol": "\ue0b0",
          "background": "#FFFB38",
          "type": "path",
          "style": "powerline"
        },
        {
          "properties": {
            "branch_icon": "\ue725 ",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "template": "{{ .UpstreamIcon }}{{ .HEAD }}{{ .BranchStatus }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<#ef5350> \uf046 {{ .Staging.String }}</>{{ end }}"
          },
          "foreground": "#000000",
          "powerline_symbol": "\ue0b0",
          "background": "#f1502f",
          "type": "git",
          "style": "powerline",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ffeb95{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#c5e478{{ end }}",
            "{{ if gt .Ahead 0 }}#C792EA{{ end }}",
            "{{ if gt .Behind 0 }}#C792EA{{ end }}"
          ]
        },
        {
          "properties": {
            "prefix": " \ue77f "
          },
          "foreground": "#000000",
          "powerline_symbol": "\ue0b0",
          "background": "#00ffff",
          "type": "dotnet",
          "style": "powerline"
        },
        {
          "properties": {
            "display_mode": "files",
            "display_version": true,
            "display_virtual_env": false,
            "prefix": " \ue235 "
          },
          "foreground": "#111111",
          "powerline_symbol": "\ue0b0",
          "background": "#FFDE57",
          "type": "python",
          "style": "powerline"
        },
        {
          "properties": {
            "prefix": " \ue718 "
          },
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#86BBD8",
          "type": "node",
          "style": "powerline"
        },
        {
          "properties": {
            "always_enabled": true,
            "postfix": "",
            "prefix": " "
          },
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#83769c",
          "type": "executiontime",
          "style": "powerline"
        },
        {
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#2e6099",
          "type": "time",
          "style": "powerline"
        },
        {
          "properties": {
            "always_enabled": true,
            "prefix": "",
            "template": " \ue23a"
          },
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#00897b",
          "type": "exit",
          "style": "powerline",
          "background_templates": [
            "{{ if gt .Code 0 }}#e91e63{{ end }}"
          ]
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "postfix": "",
            "prefix": " \uf489 "
          },
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#0077c2",
          "type": "shell",
          "style": "powerline"
        }
      ],
      "newline": true
    }
  ],
  "version": 3,
  "final_space": true
}
